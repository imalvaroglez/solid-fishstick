# Firebase project config (Firebase Console > Project settings > Your apps > SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Legacy admins who may still read/write the original root collections and
# claim the migrated default store. Keep this mirrored in Firestore/Storage
# isAdmin() rules until legacy retirement.
VITE_ADMIN_EMAILS=you@example.com,partner@example.com

# Comma-separated Firebase Auth UIDs allowed to claim the legacy default store.
# Look these up once in Firebase Console; the browser cannot resolve email→UID.
VITE_LEGACY_ADMIN_UIDS=

# Seller WhatsApp number for the public catalog, Mexican format, country code + 1, no spaces.
# Example: 5215512345678
VITE_PUBLIC_CATALOG_SELLER_PHONE=5215512345678

# Business name shown at the top of the public catalog.
VITE_PUBLIC_CATALOG_BUSINESS_NAME=Primeras Ventas

# Optional local automation credentials. Never referenced by browser/client code.
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
