rules_version = '2';

// ============================================================================
// Product images: admin-only read + write. getDownloadURL() (called by the
// admin app after upload) issues a metadata GET gated by `allow read`, so
// admins need read access to obtain the download URL. The returned URL carries
// a token, which is what the public catalog uses to render images — anonymous
// users never satisfy the read rule and cannot list or read objects directly.
//
// Storage rules CANNOT import Firestore or read Vite env vars, so isAdmin()
// must mirror the same admin email list as firestore.rules / VITE_ADMIN_EMAILS.
// ============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Admin Email/Password accounts — keep in sync with VITE_ADMIN_EMAILS.
    function isAdmin() {
      return request.auth != null
      && request.auth.token.email in [
        "admin@mail.com",
        "estebanchavez1709@gmail.com"
      ];
    }

    // Product images: admin-only read/write. getDownloadURL() issues a metadata
    // GET that is gated by `allow read`, so admins must be able to read to obtain
    // the download URL. The URL it returns carries a token, so public catalog
    // visitors fetch the image via that token WITHOUT needing the read rule —
    // anonymous users still cannot list or read these objects directly.
    match /product-images/{productId}/{allPaths=**} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // --- NEW: store-scoped product images (Store OS) ------------------------
    // Cross-service read: Storage rules reach Firestore via firestore.get()
    // (NOT bare get/getAfter — those are Firestore-only; max 2 unique reads).
    // Membership doc id is deterministic: storeId + "_" + uid (mirrors
    // firestore.rules). Public catalog visitors still use token-bearing download
    // URLs — they never satisfy this read rule.
    match /stores/{storeId}/product-images/{productId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/memberships/$(storeId + "_" + request.auth.uid))
        && firestore.get(/databases/(default)/documents/memberships/$(storeId + "_" + request.auth.uid))
             .data.uid == request.auth.uid
        && firestore.get(/databases/(default)/documents/memberships/$(storeId + "_" + request.auth.uid))
             .data.storeId == storeId
        && firestore.get(/databases/(default)/documents/memberships/$(storeId + "_" + request.auth.uid))
             .data.status == "active"
        && firestore.get(/databases/(default)/documents/memberships/$(storeId + "_" + request.auth.uid))
             .data.role in ["owner", "admin"];
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
